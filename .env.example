# ============================================================
# AI Data Pipeline Incident Investigator
# Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Airflow UID (important on Linux to avoid permission issues) ──
# Run: echo "AIRFLOW_UID=$(id -u)" >> .env
AIRFLOW_UID=50000

# ── Airflow Admin User ──
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ── Fernet Key (for encrypting connections/variables) ──
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# ── OpenAI (required) ──
OPENAI_API_KEY=sk-...

# ── LangSmith Observability ──
LANGCHAIN_API_KEY=ls-...
LANGCHAIN_PROJECT=pipeline-investigator
